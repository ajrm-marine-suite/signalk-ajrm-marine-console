{
  "name": "signalk-ajrm-marine-console",
  "version": "0.5.27",
  "description": "Suite entry point, navigation shell, and shared help for AJRM Marine applications.",
  "main": "plugin/index.js",
  "scripts": {
    "build:help": "node scripts/extract-help.js",
    "test": "node --test \"test/**/*.test.js\" && node --check plugin/index.js && node --check public/app.js",
    "prepublishOnly": "npm run build:help && npm test"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-ais",
    "ais",
    "console",
    "sailing",
    "signal-k",
    "signalk",
    "ajrm-marine-suite",
    "marine",
    "navigation"
  ],
  "author": "Anthony McDonald, with assistance from William McAusland",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajrm-marine-suite/signalk-ajrm-marine-console.git"
  },
  "bugs": {
    "url": "https://github.com/ajrm-marine-suite/signalk-ajrm-marine-console/issues"
  },
  "homepage": "https://github.com/ajrm-marine-suite/signalk-ajrm-marine-console#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "plugin",
    "public",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "displayName": "AJRM Marine Suite",
    "appIcon": "./icon.svg",
    "requires": [
      "signalk-ajrm-marine-display",
      "signalk-ajrm-marine-traffic",
      "signalk-ajrm-marine-notifications",
      "signalk-ajrm-marine-audio"
    ],
    "recommends": [
      "signalk-ajrm-marine-vessel-database",
      "signalk-ajrm-marine-capture",
      "signalk-ajrm-marine-snapshot",
      "signalk-ajrm-marine-logger",
      "signalk-ajrm-marine-voyage-viewer",
      "signalk-ajrm-marine-simulator",
      "signalk-ajrm-marine-gps-integrity",
      "signalk-ajrm-marine-dr-plotter",
      "signalk-ajrm-marine-alerts",
      "signalk-ajrm-marine-instruments",
      "signalk-ajrm-marine-instrument-alerts",
      "signalk-ajrm-marine-harbour-editor",
      "signalk-ajrm-marine-pi-controller"
    ]
  }
}
